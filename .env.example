# LLM provider: gemini (default for this repo) or openai
LLM_PROVIDER=gemini

# OpenAI (when LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google AI / Gemini (when LLM_PROVIDER=gemini)
GOOGLE_API_KEY=
# Stable chat models: gemini-2.5-flash-lite (default, cheap), gemini-2.5-flash, or gemini-2.5-pro
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001

# Optional: SerpAPI for Google search; otherwise DuckDuckGo is used
SERPAPI_API_KEY=

# true = one LLM call, no RAG (cheap). false = RAG + Analyst + Writer (two LLM calls, embeddings).
SIMPLE_MODE=false

# Demo mode: no API key, returns scripted agent steps (for CI/local smoke)
DEMO_MODE=false

# Redis (docker-compose default)
REDIS_URL=redis://redis:6379/0

# Chroma
CHROMA_HOST=chroma
CHROMA_PORT=8000

# API URL for Streamlit
API_BASE_URL=http://api:8000
